{
  "name": "qre-desktop",
  "version": "0.1.0",
  "description": "Standalone desktop app for Microsoft Quantum Resource Estimator (QRE v3)",
  "main": "out/main/index.js",
  "author": "PlexTech",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:mock": "QRE_MOCK=1 electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "provision:python": "node scripts/provision-python.mjs",
    "dist": "npm run build && npm run provision:python && electron-builder",
    "dist:mac": "npm run build && npm run provision:python && electron-builder --mac",
    "dist:win": "npm run build && npm run provision:python && electron-builder --win",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.2"
  }
}
